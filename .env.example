# ─────────────────────────────────────────────────────────────────────────────
# TEAL REGISTRY — ENVIRONMENT VARIABLES
# Copy to .env.local for local dev. Set all in Railway → Project → Variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Railway PostgreSQL) ─────────────────────────────────────────────
# Copy from Railway → PostgreSQL service → Connect tab → "DATABASE_URL"
DATABASE_URL="postgresql://postgres:PASSWORD@HOST:PORT/railway"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="REPLACE_WITH_32_CHAR_SECRET"
# Production URL (no trailing slash)
AUTH_URL="https://tealregistry.com"
# Comma-separated admin emails (auto-upgraded to ADMIN role on first sign-in)
ADMIN_EMAILS="rick@tealregistry.com"

# ── Email / SMTP (magic links + notifications) ────────────────────────────────
EMAIL_SERVER_HOST="smtp.resend.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="resend"
EMAIL_SERVER_PASSWORD="re_REPLACE_WITH_API_KEY"
EMAIL_FROM="Teal Registry <noreply@tealregistry.com>"

# ── Stripe ────────────────────────────────────────────────────────────────────
# sk_test_... for dev, sk_live_... for prod
STRIPE_SECRET_KEY="sk_test_REPLACE"
STRIPE_WEBHOOK_SECRET="whsec_REPLACE"
# Price IDs — create in Stripe Dashboard (recurring/yearly)
# Teal Verified = $1,200/yr | Teal Certified = $3,800/yr | Accredited = $2,400/yr
STRIPE_TEAL_VERIFIED="price_REPLACE"
STRIPE_TEAL_CERTIFIED="price_REPLACE"
STRIPE_ACCREDITED="price_REPLACE"

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://tealregistry.com"
NODE_ENV="production"
